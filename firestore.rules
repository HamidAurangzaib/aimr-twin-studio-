
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow account creation with required profile fields
      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.keys().hasAll(['uid', 'email', 'name', 'createdAt']);

      // Allow usage counter updates with strict limits to prevent cheating
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['imagesUsedThisMonth', 'usageMonth'])
        && (
            // New month: reset counter (capped at 4 — max single batch)
            (resource.data.usageMonth != request.resource.data.usageMonth
              && request.resource.data.imagesUsedThisMonth >= 0
              && request.resource.data.imagesUsedThisMonth <= 4)
            // Same month: can only increment, max 4 per write, hard cap at 300
            || (resource.data.usageMonth == request.resource.data.usageMonth
                && request.resource.data.imagesUsedThisMonth >= resource.data.imagesUsedThisMonth
                && (request.resource.data.imagesUsedThisMonth - resource.data.imagesUsedThisMonth) <= 4
                && request.resource.data.imagesUsedThisMonth <= 300)
           );

      allow delete: if false;
    }
  }
}

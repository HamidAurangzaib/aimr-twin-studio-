
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // User profile and usage access
    // Users can read their own documents, but CANNOT write.
    // Writes must happen via Cloud Functions (Admin SDK) to enforce limits.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // STRICT: No client-side writes.
    }
  }
}
